{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /usr/src/MiniSMS/scripts/git-leak-guard.sh",
            "timeout": 30,
            "statusMessage": "Scanning for sensitive/business tokens before git commit/push"
          }
        ]
      }
    ]
  }
}
