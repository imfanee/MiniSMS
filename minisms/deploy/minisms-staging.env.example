# Overrides for minisms-staging.service (loaded after minisms.env).
# Install: cp to /etc/minisms/minisms-staging.env && chown minisms:minisms && chmod 600

# App listens on 18081 (loopback); nginx serves TLS on :18080.
PORT=18081
HTTP_LISTEN_ADDR=127.0.0.1:18081
APP_ENV=development
LOG_LEVEL=info

# Staging database (required — do not point at production minisms)
DATABASE_URL=postgres://minisms:CHANGE_ME@localhost:5432/minisms_test?sslmode=disable

# Public admin URL (nginx TLS on :18080) — fixes CSRF "origin invalid"
# Host[:port] only (gorilla/csrf compares Referer/Origin hosts, not full URLs)
CSRF_TRUSTED_ORIGINS=YOUR_DOMAIN:18080

SMPP_SERVER_ENABLED=false
SMPP_LISTEN_ADDR=:2775

# Set true only if an upstream HTTP carrier uses a self-signed certificate
HTTP_CARRIER_INSECURE_TLS=true
