# =============================================================================
# MiniSMS Environment Configuration
# Copy to /etc/minisms/minisms.env and fill in real values
# chmod 600 /etc/minisms/minisms.env
# chown minisms:minisms /etc/minisms/minisms.env
# =============================================================================

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=SSLMODE
# Production: use sslmode=require if PostgreSQL has TLS configured
DATABASE_URL=postgres://minisms:CHANGE_THIS_PASSWORD@localhost:5432/minisms?sslmode=disable

# 32-byte hex key for AES-256-GCM encryption of carrier credentials and DLR webhook secrets
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_32_BYTE_HEX

# Bootstrap super admin (required at startup; seeds admin_users when table is empty)
ADMIN_USERNAME=admin

# bcrypt hash of bootstrap password (cost factor 12)
# Generate with: ./hashpassword   (interactive)
# Or:            echo "yourpassword" | ./hashpassword   (scripted)
# Or:            make hash-password
# After DB users exist, change operator passwords in Admin UI → Admin users
ADMIN_PASSWORD_HASH=REPLACE_WITH_BCRYPT_HASH

# 32-byte hex key for CSRF token signing (must differ from SECRET_KEY)
# Generate with: openssl rand -hex 32
CSRF_AUTH_KEY=REPLACE_WITH_32_BYTE_HEX

# HTTP listen port (ignored when HTTP_LISTEN_ADDR is set)
PORT=8080

# Optional full bind address (staging: 127.0.0.1:18081)
# HTTP_LISTEN_ADDR=127.0.0.1:18081

# Allow carrier HTTP clients with invalid TLS (lab only)
# HTTP_CARRIER_INSECURE_TLS=false

# Comma-separated admin UI origins for CSRF when not on default host:port
# CSRF_TRUSTED_ORIGINS=https://sms.example.com:18080

# Enable built-in TLS listener (normally false when running behind nginx/Caddy)
TLS_ENABLED=false

# TLS certificate file path (required when TLS_ENABLED=true)
TLS_CERT_FILE=certs/dev-cert.pem

# TLS private key file path (required when TLS_ENABLED=true)
TLS_KEY_FILE=certs/dev-key.pem

# Logging: debug | info | warn | error
LOG_LEVEL=info

# Environment: development (human-readable logs) | production (JSON logs)
APP_ENV=production

# Admin session idle timeout in minutes (default 240 = 4 hours)
SESSION_IDLE_MINUTES=240

# Per-carrier HTTP dispatch timeout in seconds (default 10)
CARRIER_DISPATCH_TIMEOUT_S=10

# -----------------------------------------------------------------------------
# SMPP (ADR §7) — global defaults; per-carrier/client rows override in DB
# -----------------------------------------------------------------------------
# Enquire link interval (seconds) when carrier row unset (default 30)
SMPP_ENQUIRE_LINK_S=30
# PDU window size when carrier row unset (default 10)
SMPP_WINDOW_SIZE=10
# submit_sm rate limit per bind when row unset (default 50/s)
SMPP_THROUGHPUT_PER_S=50

# Client SMSC ingress (ESME binds) — off until migration 004 + firewall ready
SMPP_SERVER_ENABLED=false
SMPP_LISTEN_ADDR=:2775
# Advertised system_id in bind_resp (informational)
SMPP_SYSTEM_ID=minisms

# Optional TLS on SMPP listener (L4; not nginx HTTP)
SMPP_TLS_ENABLED=false
# SMPP_TLS_CERT_FILE=/etc/minisms/certs/smpp-cert.pem
# SMPP_TLS_KEY_FILE=/etc/minisms/certs/smpp-key.pem

